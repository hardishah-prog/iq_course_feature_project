# Copy this file to .env and fill in your values

# PostgreSQL connection (overridden by docker-compose internal URL)
DATABASE_URL=postgresql://iquser:iqpass@db:5432/iqdb

# Redis connection (overridden by docker-compose internal URL)
REDIS_URL=redis://redis:6379/0

# Groq API Key — get one from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
